{
	"name": "big4dash",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"data:build": "node scripts/build-dashboard-data.mjs",
		"data:offices": "node scripts/build-office-dataset.mjs",
		"data:validate": "vitest run --project server",
		"predev": "npm run data:build",
		"dev": "vite dev",
		"prebuild": "npm run data:build",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"quality": "npm run data:build && npm run check && npm run lint && npm run test"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/d3-geo": "^3.1.0",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^24",
		"@types/three": "^0.185.1",
		"@types/topojson-client": "^3.1.5",
		"@vitest/browser-playwright": "^4.1.8",
		"csv-parse": "^7.0.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource-variable/manrope": "^5.2.8",
		"@fontsource-variable/newsreader": "^5.2.10",
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@lucide/svelte": "^1.25.0",
		"d3-geo": "^3.1.1",
		"d3-shape": "^3.2.0",
		"driver.js": "^1.8.0",
		"three": "^0.185.1",
		"topojson-client": "^3.1.0",
		"world-atlas": "^2.0.2"
	}
}
